# Makefile -- PC testing of deepbindi_cnn_x_heep (int32 variant)
#
# Usage:
#   make           build deepbindi_cnn_pc
#   make run       build and run
#   make clean     remove build artifacts
#
# For X-HEEP: add deepbindi_cnn_x_heep as an application directory and
# build via the X-HEEP CMake flow
#
# Notes:
#   -DTARGET_PC  stubs CSR macros and enables stdlib exit() in DEEPBINDI_FATAL.
#   No -lm needed: this port has no floating-point operations.

CC      = gcc
CFLAGS  = -Wall -Wextra -O2 -std=c99 -DTARGET_PC
TARGET  = deepbindi_cnn_pc
TARGET_REAL = deepbindi_cnn_pc_real
SRCS    = main.c nn_runtime.c cnn_models_c.c arena.c
OBJS    = $(SRCS:.c=.o)
OBJS_REAL = $(SRCS:.c=_real.o)

.PHONY: all run run-real clean

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# Real-weights build: requires weights_cnn_1d_v2.h generated by export_pytorch_weights.py
$(TARGET_REAL): $(OBJS_REAL)
	$(CC) $(CFLAGS) -DDEEPBINDI_REAL_WEIGHTS -o $@ $^

%_real.o: %.c
	$(CC) $(CFLAGS) -DDEEPBINDI_REAL_WEIGHTS -c -o $@ $<

run: $(TARGET)
	./$(TARGET)

run-real: $(TARGET_REAL)
	./$(TARGET_REAL)

clean:
	rm -f $(OBJS) $(OBJS_REAL) $(TARGET) $(TARGET_REAL)

# Dependencies (headers only; sources are listed above)
main.o:        main.c deepbindi_config.h cnn_models_c.h arena.h test_input.h nn_runtime.h
nn_runtime.o:  nn_runtime.c deepbindi_config.h nn_runtime.h arena.h
cnn_models_c.o: cnn_models_c.c cnn_models_c.h arena.h nn_runtime.h
arena.o:       arena.c deepbindi_config.h arena.h nn_runtime.h

# Python helper scripts (not part of the C build):
#   extract_weights.py       -- inspect TFLite model (CNN_2d_tensorflow_softmax only)
#   export_pytorch_weights.py -- load trained CNN_1D_v2 .pth and write weights_cnn_1d_v2.h
